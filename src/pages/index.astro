---
import BaseLayout from "../layouts/BaseLayout.astro";

const introText =
  "I research humans and use design to make them fall in love with tech. Exploring the intersection of cognitive science and digital experiences.";

const contacts = [
  { label: "Email", href: "mailto:abel.aagh@gmail.com", external: false },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/abel-a-gonzalez",
    external: true,
  },
  { label: "GitHub", href: "https://github.com/aagh-jr", external: true },
];
---

<BaseLayout title="Abel Angel — Portfolio" bodyClass="zoom-home home-no-scroll">
  <main id="home" data-load-stagger>
    <div class="bento-outer">
      <div class="bento-inner">
        <div class="bento-grid">
          <!-- ── Hero card ── -->
          <div class="hero-card">
            <div class="hero-title" data-load-item>
              <span>Hey! I'm </span><span>Abel Angel</span>
            </div>
            <div class="hero-sub" data-load-item>
              <span class="intro-line">{introText}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Bottom-right nav ── -->
    <div class="corner-nav corner-nav--right" data-load-item>
      <a href="/about" class="corner-link">
        About
        <svg width="39" height="39" viewBox="0 0 52 52" fill="none" aria-hidden="true">
          <mask id="navknock-about" maskUnits="userSpaceOnUse" x="0" y="0" width="52" height="52">
            <rect width="52" height="52" fill="white"></rect>
            <g stroke="black" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
              <path d="M16 26H36"></path>
              <path d="M28 18L36 26L28 34"></path>
            </g>
          </mask>
          <circle cx="26" cy="26" r="23" fill="currentColor" mask="url(#navknock-about)"></circle>
        </svg>
      </a>
      <a href="/projects" class="corner-link">
        Projects
        <svg width="39" height="39" viewBox="0 0 52 52" fill="none" aria-hidden="true">
          <mask id="navknock-projects" maskUnits="userSpaceOnUse" x="0" y="0" width="52" height="52">
            <rect width="52" height="52" fill="white"></rect>
            <g stroke="black" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
              <path d="M16 26H36"></path>
              <path d="M28 18L36 26L28 34"></path>
            </g>
          </mask>
          <circle cx="26" cy="26" r="23" fill="currentColor" mask="url(#navknock-projects)"></circle>
        </svg>
      </a>
    </div>

    <!-- ── Bottom-left contact nav ── -->
    <div class="corner-nav corner-nav--left" data-load-item>
      {
        contacts.map((c) => (
          <a
            href={c.href}
            class="corner-link corner-link--contact"
            target={c.external ? "_blank" : undefined}
            rel={c.external ? "noreferrer" : undefined}
          >
            {c.label}
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* Home + About share the original 1.2 zoom, applied via a body class. */
  body.zoom-home {
    zoom: 1.2;
  }

  /* Home only: it's a single-screen hero, so never scroll the document.
     Scoped to this class (not the shared zoom-home) so the About page,
     which does scroll, is unaffected. */
  html:has(body.home-no-scroll),
  body.home-no-scroll {
    height: 100svh;
    overflow: hidden;
    overscroll-behavior: none;
  }
</style>

<style>
  .bento-outer {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .bento-inner {
    padding: 48px 0 96px;
  }
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .hero-card {
    grid-column: 1 / -1;
    min-height: 260px;
    padding-top: 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .hero-title {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.016em;
    line-height: 1;
    margin-bottom: 24px;
    color: #000;
  }
  .hero-sub {
    font-size: 40px;
    font-weight: 800;
    color: #71717a;
    letter-spacing: -0.016em;
    line-height: 1.2;
    max-width: 50vw;
  }
  .intro-line { display: block; }

  .corner-nav {
    position: fixed;
    bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 100;
  }
  .corner-nav--right {
    right: max(63px, calc((100vw / 1.2 - 1280px) / 2 + 63px));
    align-items: flex-end;
  }
  .corner-nav--left {
    left: max(63px, calc((100vw / 1.2 - 1280px) / 2 + 63px));
    align-items: flex-start;
  }
  .corner-link {
    font-size: 40px;
    font-weight: 800;
    color: #1c1c18;
    letter-spacing: -0.016em;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: color 0.15s;
  }
  .corner-link--contact { height: 54px; }
  .corner-link:hover { color: #71717a; }

  @media (max-width: 768px) {
    .bento-outer { padding: 0 20px; }
    .bento-grid { grid-template-columns: 1fr; }
  }
</style>
