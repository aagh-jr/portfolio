---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects | Abel Angel"
  description="Selected UX research and product design work by Abel Angel — Energy Ave, Cabrillo National Monument, and more."
  canonical="/projects"
>
  <div class="page-wrap">
    <main class="content">
      <div class="page-head">
        <a class="back-circle" href="/" aria-label="Back to home">
          <svg width="39" height="39" viewBox="0 0 52 52" fill="none">
            <mask id="backknock" maskUnits="userSpaceOnUse" x="0" y="0" width="52" height="52">
              <rect width="52" height="52" fill="white"></rect>
              <g stroke="black" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
                <path d="M16 26H36"></path>
                <path d="M24 18L16 26L24 34"></path>
              </g>
            </mask>
            <circle cx="26" cy="26" r="23" fill="currentColor" mask="url(#backknock)"></circle>
          </svg>
        </a>
        <h1 class="page-title">Projects</h1>
      </div>

      <div class="masonry">
        {
          projects.map((p) => {
            const soon = p.data.status === "coming-soon";
            const Tag = soon ? "div" : "a";
            const props = soon ? {} : { href: p.data.href };
            return (
              <Tag
                class:list={[
                  "tile",
                  p.data.pile && `tile--${p.data.pile}`,
                  soon && "tile--soon",
                ]}
                {...props}
              >
                <div
                  class:list={[
                    "tile-image",
                    p.data.variant === "pile" && "tile-image--pile",
                  ]}
                  style={
                    p.data.variant === "cover"
                      ? `background:${p.data.coverBg};`
                      : undefined
                  }
                >
                  {p.data.pile === "ea" && (
                    <div class="pile">
                      <div class="pile-photo pile-photo--screen" />
                      <div class="pile-photo pile-photo--card" />
                    </div>
                  )}
                  {p.data.pile === "cabrillo" && (
                    <div class="pile">
                      <div class="pile-photo pile-photo--nps" />
                      <div class="pile-photo pile-photo--wb" />
                      <div class="pile-photo pile-photo--otd" />
                    </div>
                  )}
                  {p.data.variant === "cover" && (
                    <span class="cover-label" style={`color:${p.data.coverFg};`}>
                      {p.data.coverLabel}
                    </span>
                  )}
                </div>

                <div class="tile-meta">
                  <div class="tile-title">{p.data.title}</div>
                  <div class="tile-tagline">{p.data.tagline}</div>
                  <div class="tile-tags">
                    {soon && <span class="tag tag--soon">Coming Soon</span>}
                    {p.data.tags.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                </div>
              </Tag>
            );
          })
        }
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  /* ── Entrance: slide the list up (preserved from the original) ── */
  @keyframes masonrySlideUp {
    from { transform: translateY(60vh); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  .masonry {
    animation: masonrySlideUp 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }
  @media (prefers-reduced-motion: reduce) {
    .masonry { animation: none; }
  }

  /* ── Layout ── */
  .page-wrap {
    width: 100%;
    min-height: 100vh;
    padding: 88px 64px 80px;
    display: flex;
    justify-content: center;
  }
  .content { width: 100%; max-width: 760px; }
  .page-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 44px;
  }
  .page-title {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.016em;
    line-height: 1;
    color: #1c1c18;
  }
  .back-circle {
    color: #1c1c18;
    display: inline-flex;
    line-height: 0;
    transition: color 180ms;
  }
  .back-circle:hover { color: #71717a; }
  .masonry {
    width: 100%;
    margin-top: 70px;
    display: flex;
    flex-direction: column;
    gap: 44px;
  }

  /* ── Rows ── */
  .tile {
    display: flex;
    align-items: center;
    gap: 50px;
    transition: transform 280ms cubic-bezier(0.2, 0, 0, 1);
    color: inherit;
    text-decoration: none;
  }
  .tile:hover { transform: translateY(-4px); }
  .tile--soon { cursor: default; }
  .tile--soon:hover { transform: translateY(-4px); }

  .tile-image {
    flex: 0 0 284px;
    width: 284px;
    aspect-ratio: 5 / 4;
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cover-label {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  /* ── Photo-pile (Energy Ave) ── */
  .tile-image--pile { overflow: visible; border-radius: 0; }
  .pile { position: absolute; inset: 0; }
  .pile-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 8px;
    background: #fff center/cover no-repeat;
    transform-origin: center bottom;
    transition: transform 360ms cubic-bezier(0.2, 0, 0, 1);
  }
  .pile-photo--screen {
    background-image: url(/uploads/ea-title-hifi.png);
    transform: rotate(-6deg) translate(-6px, -5px);
  }
  .pile-photo--card {
    background-image: url(/uploads/ea-figma-hifi-card-computer-07.png);
    background-color: #11161c;
    background-size: contain;
    background-position: center;
    inset: auto;
    top: 21px;
    right: 6px;
    width: 138px;
    height: auto;
    aspect-ratio: 900 / 1074;
    transform: rotate(7deg) translate(12px, 3px);
  }
  .tile--ea:hover .pile-photo--screen { transform: rotate(-11deg) translate(-23px, -10px); }
  .tile--ea:hover .pile-photo--card   { transform: rotate(11deg) translate(13px, -4px); }

  /* ── Cabrillo NPS pile ── */
  .pile-photo--nps {
    background-color: #1b3a28;
    background-image: url(/uploads/cabrillo-nps-logo.png);
    background-size: 45% auto;
    background-position: center;
    transform: rotate(-1deg);
  }
  .pile-photo--wb,
  .pile-photo--otd {
    inset: auto;
    width: 129px;
    height: auto;
    aspect-ratio: 990 / 1530;
    background-size: cover;
    background-position: center;
  }
  .pile-photo--wb  { background-image: url(/screenshots/cabrillo/wb-1-cover.png);  left: 39px;  top: 12px; transform: rotate(-7deg) translate(-14px, 0); }
  .pile-photo--otd { background-image: url(/screenshots/cabrillo/otd-1-cover.png); right: 39px; top: 21px; transform: rotate(7deg) translate(17px, 3px); }
  .tile--cabrillo:hover .pile-photo--nps { transform: rotate(-3deg) translate(-3px, 3px); }
  .tile--cabrillo:hover .pile-photo--wb  { transform: rotate(-15deg) translate(-30px, -8px); }
  .tile--cabrillo:hover .pile-photo--otd { transform: rotate(12deg) translate(14px, -6px); }

  /* ── Meta ── */
  .tile-meta {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tile-title {
    font-size: 40px;
    font-weight: 800;
    color: #1c1c18;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .tile-tagline {
    font-size: 15px;
    color: #71717a;
    line-height: 1.6;
  }
  .tile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  .tag {
    font-size: 12px;
    font-weight: 500;
    color: #1c1c18;
    background: transparent;
    border: 1px solid rgba(28, 28, 24, 0.25);
    padding: 4px 11px;
    border-radius: 999px;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .tag--soon {
    color: #fffafa;
    background: #1c1c18;
    border-color: #1c1c18;
    font-weight: 600;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .page-wrap { padding: 88px 24px 56px; }
    .masonry { gap: 32px; }
    .tile { flex-direction: column; align-items: stretch; gap: 16px; }
    .tile-image { flex: 0 0 auto; width: 100%; }
  }
</style>
