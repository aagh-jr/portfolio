---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects | Abel Angel"
  description="Selected UX research and product design work by Abel Angel — Energy Ave, Cabrillo National Monument, and more."
  canonical="/projects"
>
  <div class="page-wrap">
    <main class="content">
      <div class="page-head">
        <a class="back-circle" href="/" aria-label="Back to home">
          <svg width="39" height="39" viewBox="0 0 52 52" fill="none">
            <mask id="backknock" maskUnits="userSpaceOnUse" x="0" y="0" width="52" height="52">
              <rect width="52" height="52" fill="white"></rect>
              <g stroke="black" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
                <path d="M16 26H36"></path>
                <path d="M24 18L16 26L24 34"></path>
              </g>
            </mask>
            <circle cx="26" cy="26" r="23" fill="currentColor" mask="url(#backknock)"></circle>
          </svg>
        </a>
        <h1 class="page-title">Projects</h1>

        <div class="view-toggle" role="group" aria-label="Layout">
          <button class="vt-btn" data-cols="1" aria-label="One per row" aria-pressed="false">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="2" y="3" width="14" height="12" rx="2" fill="currentColor"></rect>
            </svg>
          </button>
          <button class="vt-btn" data-cols="2" aria-label="Two per row" aria-pressed="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="2" y="3" width="6" height="12" rx="1.5" fill="currentColor"></rect>
              <rect x="10" y="3" width="6" height="12" rx="1.5" fill="currentColor"></rect>
            </svg>
          </button>
        </div>
      </div>

      <div class="masonry cols-2" id="grid">
        {
          projects.map((p) => {
            const soon = p.data.status === "coming-soon";
            const Tag = soon ? "div" : "a";
            const props = soon ? {} : { href: p.data.href };
            return (
              <Tag
                class:list={[
                  "tile",
                  p.data.pile && `tile--${p.data.pile}`,
                  soon && "tile--soon",
                ]}
                {...props}
              >
                <div
                  class:list={[
                    "tile-image",
                    p.data.variant === "pile" && "tile-image--pile",
                  ]}
                  style={
                    p.data.variant === "cover"
                      ? `background:${p.data.coverBg};`
                      : undefined
                  }
                >
                  {p.data.pile === "ea" && (
                    <div class="pile">
                      <div class="pile-photo pile-photo--screen" />
                      <div class="pile-photo pile-photo--card" />
                    </div>
                  )}
                  {p.data.pile === "cabrillo" && (
                    <div class="pile">
                      <div class="pile-photo pile-photo--nps" />
                      <div class="pile-photo pile-photo--wb" />
                      <div class="pile-photo pile-photo--otd" />
                    </div>
                  )}
                  {p.data.variant === "cover" && (
                    <span class="cover-label" style={`color:${p.data.coverFg};`}>
                      {p.data.coverLabel}
                    </span>
                  )}
                </div>

                <div class="tile-meta">
                  <div class="tile-title">{p.data.title}</div>
                  <div class="tile-tagline">{p.data.tagline}</div>
                  <div class="tile-tags">
                    {soon && <span class="tag tag--soon">Coming Soon</span>}
                    {p.data.tags.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                </div>
              </Tag>
            );
          })
        }
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  /* Entrance: the whole grid slides up — initial document load only.
     Hidden pre-paint via the reveal-ready guard (added by the head script
     on first load only), then animated/shown by JS. Client-side navs are
     clean View Transition cross-fades. */
  :global(html.reveal-ready) #grid { opacity: 0; }

  .page-wrap {
    width: 100%;
    min-height: 100vh;
    padding: 88px 64px 80px;
    display: flex;
    justify-content: center;
  }
  .content { width: 100%; max-width: 760px; }

  .page-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 44px;
  }
  .page-title {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.016em;
    line-height: 1;
    color: #1c1c18;
  }
  .back-circle {
    color: #1c1c18;
    display: inline-flex;
    line-height: 0;
    transition: color 180ms;
  }
  .back-circle:hover { color: #71717a; }

  /* View toggle */
  .view-toggle {
    margin-left: auto;
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid rgba(28, 28, 24, 0.14);
    border-radius: 999px;
  }
  .vt-btn {
    width: 34px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    border-radius: 999px;
    color: #b4b4ad;
    cursor: pointer;
    transition: color 160ms, background 160ms;
  }
  .vt-btn:hover { color: #71717a; }
  .vt-btn[aria-pressed="true"] {
    color: #fffafa;
    background: #1c1c18;
  }

  /* Grid */
  .masonry {
    width: 100%;
    margin-top: 70px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px 24px;
  }
  .masonry.cols-2 {
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 28px;
  }

  /* Card: photo over text */
  .tile {
    display: flex;
    flex-direction: column;
    gap: 20px;
    color: inherit;
    text-decoration: none;
  }
  .tile-image {
    width: 100%;
    aspect-ratio: 5 / 4;
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    container-type: inline-size;
    transition: transform 280ms cubic-bezier(0.2, 0, 0, 1),
      box-shadow 280ms cubic-bezier(0.2, 0, 0, 1);
  }
  .tile:hover .tile-image {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -24px rgba(28, 28, 24, 0.45);
  }
  .cover-label {
    font-size: 30px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  /* ── Photo-pile, scaled to the card via container-query width (cqw) ── */
  .tile-image--pile { overflow: visible; border-radius: 0; box-shadow: none !important; }
  .tile:hover .tile-image--pile { box-shadow: none; }
  .pile { position: absolute; inset: 0; }
  .pile-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 2.8cqw;
    background: #fff center/cover no-repeat;
    transform-origin: center bottom;
    transition: transform 360ms cubic-bezier(0.2, 0, 0, 1);
  }
  .pile-photo--screen {
    background-image: url(/uploads/ea-title-hifi.png);
    transform: rotate(-6deg) translate(-2.11cqw, -1.76cqw);
  }
  .pile-photo--card {
    background-image: url(/uploads/ea-figma-hifi-card-computer-07.png);
    background-color: #11161c;
    background-size: contain;
    background-position: center;
    inset: auto;
    top: 7.39cqw;
    right: 2.11cqw;
    width: 48.6cqw;
    height: auto;
    aspect-ratio: 900 / 1074;
    transform: rotate(7deg) translate(4.23cqw, 1.06cqw);
  }
  .tile--ea:hover .pile-photo--screen { transform: rotate(-11deg) translate(-8.10cqw, -3.52cqw); }
  .tile--ea:hover .pile-photo--card   { transform: rotate(11deg) translate(4.58cqw, -1.41cqw); }

  .pile-photo--nps {
    background-color: #1b3a28;
    background-image: url(/uploads/cabrillo-nps-logo.png);
    background-size: 45% auto;
    background-position: center;
    transform: rotate(-1deg);
  }
  .pile-photo--wb,
  .pile-photo--otd {
    inset: auto;
    width: 45.4cqw;
    height: auto;
    aspect-ratio: 990 / 1530;
    background-size: cover;
    background-position: center;
  }
  .pile-photo--wb  { background-image: url(/screenshots/cabrillo/wb-1-cover.png);  left: 13.7cqw; top: 4.23cqw; transform: rotate(-7deg) translate(-4.93cqw, 0); }
  .pile-photo--otd { background-image: url(/screenshots/cabrillo/otd-1-cover.png); right: 13.7cqw; top: 7.39cqw; transform: rotate(7deg) translate(5.99cqw, 1.06cqw); }
  .tile--cabrillo:hover .pile-photo--nps { transform: rotate(-3deg) translate(-1.06cqw, 1.06cqw); }
  .tile--cabrillo:hover .pile-photo--wb  { transform: rotate(-15deg) translate(-10.56cqw, -2.82cqw); }
  .tile--cabrillo:hover .pile-photo--otd { transform: rotate(12deg) translate(4.93cqw, -2.11cqw); }

  /* Meta */
  .tile-meta { display: flex; flex-direction: column; gap: 10px; }
  .tile-title {
    font-size: 34px;
    font-weight: 800;
    color: #1c1c18;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .tile-tagline { font-size: 15px; color: #71717a; line-height: 1.6; }
  .tile-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
  .tag {
    font-size: 12px;
    font-weight: 500;
    color: #1c1c18;
    background: transparent;
    border: 1px solid rgba(28, 28, 24, 0.25);
    padding: 4px 11px;
    border-radius: 999px;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .tag--soon {
    color: #fffafa;
    background: #1c1c18;
    border-color: #1c1c18;
    font-weight: 600;
  }

  .tile--soon { cursor: default; }

  @media (max-width: 720px) {
    .page-wrap { padding: 88px 24px 56px; }
    .masonry, .masonry.cols-2 { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<script>
  const KEY = "projCols";

  function applyCols(grid: HTMLElement, cols: string) {
    grid.classList.toggle("cols-1", cols === "1");
    grid.classList.toggle("cols-2", cols === "2");
    document.querySelectorAll<HTMLElement>(".vt-btn").forEach((b) =>
      b.setAttribute(
        "aria-pressed",
        b.dataset.cols === cols ? "true" : "false",
      ),
    );
  }

  function initProjects() {
    const grid = document.getElementById("grid");
    if (!grid || grid.dataset.wired) return;
    grid.dataset.wired = "1";

    // Restore saved layout preference.
    const saved = localStorage.getItem(KEY) || "2";
    applyCols(grid, saved);
    document.querySelectorAll<HTMLElement>(".vt-btn").forEach((btn) =>
      btn.addEventListener("click", () => {
        const cols = btn.dataset.cols || "2";
        localStorage.setItem(KEY, cols);
        applyCols(grid, cols);
      }),
    );

    // Entrance: slide the grid up — initial document load only.
    const reduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (reduced || window.__spaNav) {
      grid.style.opacity = "1";
    } else {
      grid.animate(
        [
          { transform: "translateY(60vh)", opacity: 0 },
          { transform: "translateY(0)", opacity: 1 },
        ],
        { duration: 1100, easing: "cubic-bezier(0.16, 1, 0.3, 1)", delay: 50, fill: "both" },
      );
      grid.style.opacity = "1";
    }
  }

  initProjects();
  if (!window.__projWired) {
    window.__projWired = true;
    document.addEventListener("astro:page-load", initProjects);
  }
</script>
